# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=barbers
POSTGRES_PASSWORD=barbers_secret
POSTGRES_DB=barbers_db
DATABASE_URL=postgresql://barbers:barbers_secret@localhost:5432/barbers_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# ─── Storage (MinIO en dev / S3 en prod) ─────────────────────────────────────
# Dev (MinIO local):
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minio_secret
STORAGE_BUCKET=barbers
STORAGE_REGION=us-east-1

# Prod (AWS S3) — reemplazar con:
# STORAGE_ENDPOINT=s3.amazonaws.com
# STORAGE_PORT=          # dejar vacío, se usa 443 automáticamente con SSL
# STORAGE_USE_SSL=true
# STORAGE_ACCESS_KEY=<AWS_ACCESS_KEY_ID>
# STORAGE_SECRET_KEY=<AWS_SECRET_ACCESS_KEY>
# STORAGE_BUCKET=peluqarte-uploads
# STORAGE_REGION=us-east-1

# ─── Auth ────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change_me_to_a_random_32_char_string
BETTER_AUTH_URL=http://localhost:4000

# ─── Notifications ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=turnos@tupeluqueria.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ─────────────────────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# ─── Cancellation policy ─────────────────────────────────────────────────────
CANCELLATION_HOURS_LIMIT=24
DEPOSIT_AMOUNT_ARS=1000
