generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  STAFF
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  EMAIL
  SMS
}

enum NotificationStatus {
  SENT
  FAILED
  PENDING
}

enum LoyaltyEventReason {
  APPOINTMENT_COMPLETED
  REFERRAL
  MANUAL_ADJUSTMENT
  REDEEMED
}

// ─── Auth (Better Auth compatible) ───────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String?  @unique
  name          String
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  role          Role     @default(CLIENT)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  staffProfile         StaffProfile?
  clientProfile        ClientProfile?
  appointmentsAsClient Appointment[]    @relation("ClientAppointments")
  reviews              Review[]
  notificationLogs     NotificationLog[]
  sessions             Session[]
  accounts             Account[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verifications")
}

// ─── Staff & Client Profiles ─────────────────────────────────────────────────

model StaffProfile {
  id                   String  @id @default(uuid())
  userId               String  @unique @map("user_id")
  bio                  String?
  specialties          String[]
  instagramUrl         String? @map("instagram_url")
  acceptsOnlineBooking Boolean @default(true) @map("accepts_online_booking")
  commissionPct        Float   @default(0) @map("commission_pct")

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workingHours  WorkingHours[]
  timeOff       TimeOff[]
  staffServices StaffService[]
  appointments  Appointment[]   @relation("StaffAppointments")
  galleryPhotos GalleryPhoto[]

  @@map("staff_profiles")
}

model ClientProfile {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  preferredStaffId String?   @map("preferred_staff_id")
  notes            String?
  birthDate        DateTime? @map("birth_date")
  loyaltyPoints    Int       @default(0) @map("loyalty_points")
  totalVisits      Int       @default(0) @map("total_visits")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  loyaltyEvents LoyaltyEvent[]
  waitlistItems Waitlist[]

  @@map("client_profiles")
}

// ─── Services ────────────────────────────────────────────────────────────────

model Service {
  id              String   @id @default(uuid())
  name            String
  description     String?
  durationMinutes Int      @map("duration_minutes")
  price           Float
  category        String?
  photoUrl        String?  @map("photo_url")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  staffServices StaffService[]
  appointments  Appointment[]
  galleryPhotos GalleryPhoto[]
  waitlistItems Waitlist[]

  @@map("services")
}

model StaffService {
  staffId        String @map("staff_id")
  serviceId      String @map("service_id")
  customPrice    Float? @map("custom_price")
  customDuration Int?   @map("custom_duration")

  staff   StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_services")
}

// ─── Scheduling ──────────────────────────────────────────────────────────────

model WorkingHours {
  id        String  @id @default(uuid())
  staffId   String  @map("staff_id")
  dayOfWeek Int     @map("day_of_week")
  startTime String  @map("start_time")
  endTime   String  @map("end_time")
  isActive  Boolean @default(true) @map("is_active")

  staff StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@map("working_hours")
}

model TimeOff {
  id        String   @id @default(uuid())
  staffId   String   @map("staff_id")
  date      DateTime @db.Date
  startTime String?  @map("start_time")
  endTime   String?  @map("end_time")
  reason    String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  staff StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("time_off")
}

// ─── Appointments ────────────────────────────────────────────────────────────

model Appointment {
  id                 String            @id @default(uuid())
  clientId           String            @map("client_id")
  staffId            String            @map("staff_id")
  serviceId          String            @map("service_id")
  startAt            DateTime          @map("start_at")
  endAt              DateTime          @map("end_at")
  status             AppointmentStatus @default(PENDING)
  depositAmount      Float?            @map("deposit_amount")
  depositPaid        Boolean           @default(false) @map("deposit_paid")
  mpPaymentId        String?           @map("mp_payment_id")
  cancellationReason String?           @map("cancellation_reason")
  notes              String?
  reminderSent       Boolean           @default(false) @map("reminder_sent")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  client       User         @relation("ClientAppointments", fields: [clientId], references: [id])
  staff        StaffProfile @relation("StaffAppointments", fields: [staffId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])
  review       Review?
  loyaltyEvent LoyaltyEvent?

  @@index([staffId, startAt])
  @@index([clientId, startAt])
  @@map("appointments")
}

// ─── Waitlist ────────────────────────────────────────────────────────────────

model Waitlist {
  id                String    @id @default(uuid())
  clientId          String    @map("client_id")
  serviceId         String    @map("service_id")
  staffId           String?   @map("staff_id")
  requestedDate     DateTime  @map("requested_date") @db.Date
  requestedTimeFrom String?   @map("requested_time_from")
  requestedTimeTo   String?   @map("requested_time_to")
  notifiedAt        DateTime? @map("notified_at")
  expiresAt         DateTime  @map("expires_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  client  ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service       @relation(fields: [serviceId], references: [id])

  @@map("waitlist")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(uuid())
  appointmentId String   @unique @map("appointment_id")
  clientId      String   @map("client_id")
  staffId       String   @map("staff_id")
  rating        Int
  comment       String?
  photos        String[]
  isVisible     Boolean  @default(true) @map("is_visible")
  createdAt     DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  client      User        @relation(fields: [clientId], references: [id])

  @@index([staffId])
  @@map("reviews")
}

// ─── Gallery ─────────────────────────────────────────────────────────────────

model GalleryPhoto {
  id         String   @id @default(uuid())
  staffId    String   @map("staff_id")
  serviceId  String?  @map("service_id")
  beforeUrl  String?  @map("before_url")
  afterUrl   String   @map("after_url")
  caption    String?
  tags       String[]
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  staff   StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service?     @relation(fields: [serviceId], references: [id])

  @@map("gallery_photos")
}

// ─── Loyalty ─────────────────────────────────────────────────────────────────

model LoyaltyEvent {
  id            String             @id @default(uuid())
  clientId      String             @map("client_id")
  appointmentId String?            @unique @map("appointment_id")
  pointsDelta   Int                @map("points_delta")
  reason        LoyaltyEventReason
  createdAt     DateTime           @default(now()) @map("created_at")

  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment Appointment?  @relation(fields: [appointmentId], references: [id])

  @@map("loyalty_events")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model NotificationLog {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  type       NotificationType
  template   String
  sentAt     DateTime?          @map("sent_at")
  status     NotificationStatus @default(PENDING)
  externalId String?            @map("external_id")
  createdAt  DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notification_logs")
}
